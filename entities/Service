{
  "name": "Service",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Service name"
    },
    "name_ar": {
      "type": "string",
      "description": "Service name in Arabic"
    },
    "category": {
      "type": "string",
      "enum": [
        "shoes",
        "bags"
      ],
      "description": "shoes or bags"
    },
    "description": {
      "type": "string"
    },
    "price": {
      "type": "number",
      "description": "Price in SAR"
    },
    "duration_minutes": {
      "type": "number",
      "default": 30,
      "description": "Duration in minutes"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "image_url": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "name_ar",
    "category",
    "price",
    "duration_minutes"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": {
              "$in": [
                "admin",
                "staff"
              ]
            }
          }
        },
        {
          "data.is_active": true
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}