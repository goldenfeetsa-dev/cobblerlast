{
  "name": "WorkflowStage",
  "type": "object",
  "properties": {
    "order_id": {
      "type": "string",
      "description": "ID of the linked order"
    },
    "order_number": {
      "type": "string",
      "description": "Order number for quick lookup"
    },
    "customer_phone": {
      "type": "string",
      "description": "Primary key for customer lookup"
    },
    "customer_name": {
      "type": "string"
    },
    "branch_id": {
      "type": "string",
      "description": "Source branch"
    },
    "branch_name": {
      "type": "string"
    },
    "stage": {
      "type": "string",
      "enum": [
        "reception",
        "logistics_out",
        "factory_processing",
        "quality_check",
        "logistics_return",
        "ready_for_pickup"
      ],
      "default": "reception",
      "description": "Current workflow stage"
    },
    "technician_name": {
      "type": "string",
      "description": "Assigned technician at factory"
    },
    "repair_type": {
      "type": "string",
      "description": "Type of repair/service"
    },
    "stage_notes": {
      "type": "string",
      "description": "Notes for current stage"
    },
    "dispatched_to_factory_at": {
      "type": "string",
      "description": "Timestamp when sent to factory"
    },
    "returned_to_branch_at": {
      "type": "string",
      "description": "Timestamp when returned to branch"
    },
    "notified_customer_at": {
      "type": "string",
      "description": "Timestamp when customer was notified"
    }
  },
  "required": [
    "order_id",
    "order_number",
    "customer_phone",
    "branch_id"
  ]
}