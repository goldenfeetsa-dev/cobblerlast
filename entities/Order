{
  "name": "Order",
  "type": "object",
  "properties": {
    "order_number": {
      "type": "string",
      "description": "Unique order number for barcode"
    },
    "employee_id": {
      "type": "string",
      "description": "ID of employee who created the order"
    },
    "employee_name": {
      "type": "string",
      "description": "Name of employee who created the order"
    },
    "branch_id": {
      "type": "string",
      "description": "ID of the branch where this order was created"
    },
    "branch_name": {
      "type": "string",
      "description": "Name of the branch (denormalized)"
    },
    "customer_id": {
      "type": "string",
      "description": "ID of the customer"
    },
    "customer_name": {
      "type": "string",
      "description": "Customer name"
    },
    "customer_phone": {
      "type": "string",
      "description": "Customer phone"
    },
    "item_type": {
      "type": "string",
      "enum": [
        "shoes",
        "bag",
        "dress",
        "suit",
        "jacket",
        "pants",
        "shirt",
        "other"
      ],
      "description": "Type of item"
    },
    "quantity": {
      "type": "number",
      "default": 1,
      "description": "Number of pieces"
    },
    "photos": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Up to 5 photo URLs"
    },
    "delivery_method": {
      "type": "string",
      "enum": [
        "pickup",
        "delivery"
      ],
      "default": "pickup",
      "description": "Pickup or delivery"
    },
    "delivery_address": {
      "type": "string",
      "description": "Delivery address if delivery method is delivery"
    },
    "subtotal": {
      "type": "number",
      "description": "Price before VAT"
    },
    "vat_amount": {
      "type": "number",
      "description": "VAT 15% amount"
    },
    "total_price": {
      "type": "number",
      "description": "Total price including VAT"
    },
    "payment_status": {
      "type": "string",
      "enum": [
        "paid",
        "unpaid"
      ],
      "default": "unpaid",
      "description": "Payment status"
    },
    "payment_method": {
      "type": "string",
      "enum": [
        "cash",
        "network"
      ],
      "description": "Payment method"
    },
    "order_status": {
      "type": "string",
      "enum": [
        "pending",
        "in_progress",
        "ready",
        "completed",
        "cancelled",
        "returned",
        "exchanged",
        "on_hold"
      ],
      "default": "pending",
      "description": "Current order status"
    },
    "shelf_location": {
      "type": "string",
      "description": "Shelf/location where the item is stored when ready"
    },
    "hold_reason": {
      "type": "string",
      "description": "Reason for putting the order on hold"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes"
    },
    "points_earned": {
      "type": "number",
      "default": 0,
      "description": "Loyalty points earned from this order"
    }
  },
  "required": [
    "order_number",
    "employee_id",
    "customer_name",
    "item_type",
    "total_price"
  ]
}