{
  "name": "SiteVisit",
  "type": "object",
  "properties": {
    "page": {
      "type": "string",
      "description": "Page visited"
    },
    "country": {
      "type": "string",
      "description": "Country from IP geolocation"
    },
    "city": {
      "type": "string",
      "description": "City from IP geolocation"
    },
    "region": {
      "type": "string",
      "description": "Region from IP geolocation"
    },
    "ip": {
      "type": "string",
      "description": "Visitor IP (hashed for privacy)"
    },
    "user_agent": {
      "type": "string",
      "description": "Browser user agent"
    },
    "referrer": {
      "type": "string",
      "description": "Referrer URL"
    },
    "is_mobile": {
      "type": "boolean",
      "description": "Is mobile device"
    }
  },
  "required": [
    "page"
  ],
  "rls": {
    "create": {},
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {},
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}