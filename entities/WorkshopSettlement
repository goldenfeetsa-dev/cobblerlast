{
  "name": "WorkshopSettlement",
  "type": "object",
  "properties": {
    "month_key": {
      "type": "string",
      "description": "YYYY-MM"
    },
    "month_label": {
      "type": "string",
      "description": "e.g. \u064a\u0648\u0646\u064a\u0648 2026"
    },
    "settlement_items": {
      "type": "array",
      "description": "[{item_id, item_name, unit, actual_qty_used, cost_price, total_cost}]",
      "items": {
        "type": "object"
      }
    },
    "total_workshop_cost": {
      "type": "number",
      "description": "\u0625\u062c\u0645\u0627\u0644\u064a \u062a\u0643\u0627\u0644\u064a\u0641 \u0627\u0644\u0648\u0631\u0634\u0629"
    },
    "total_sales_revenue": {
      "type": "number",
      "description": "\u0625\u062c\u0645\u0627\u0644\u064a \u0645\u0628\u064a\u0639\u0627\u062a \u0627\u0644\u0634\u0647\u0631"
    },
    "total_sales_cost": {
      "type": "number",
      "description": "\u0625\u062c\u0645\u0627\u0644\u064a \u062a\u0643\u0644\u0641\u0629 \u0627\u0644\u0628\u0636\u0627\u0639\u0629 \u0627\u0644\u0645\u0628\u0627\u0639\u0629"
    },
    "gross_profit": {
      "type": "number",
      "description": "\u0625\u062c\u0645\u0627\u0644\u064a \u0631\u0628\u062d \u0627\u0644\u0645\u0628\u064a\u0639\u0627\u062a"
    },
    "net_profit": {
      "type": "number",
      "description": "\u0635\u0627\u0641\u064a \u0627\u0644\u0631\u0628\u062d \u0628\u0639\u062f \u062e\u0635\u0645 \u0627\u0644\u0648\u0631\u0634\u0629"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "approved"
      ],
      "default": "draft"
    },
    "approved_by": {
      "type": "string"
    },
    "approved_at": {
      "type": "string"
    },
    "journal_entry": {
      "type": "string",
      "description": "\u0627\u0644\u0642\u064a\u062f \u0627\u0644\u0645\u062d\u0627\u0633\u0628\u064a \u0627\u0644\u0645\u0648\u0644\u0651\u062f \u062a\u0644\u0642\u0627\u0626\u064a\u0627\u064b"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "month_key"
  ]
}