{
  "name": "Booking",
  "type": "object",
  "properties": {
    "booking_number": {
      "type": "string",
      "description": "Unique booking reference"
    },
    "customer_name": {
      "type": "string"
    },
    "customer_phone": {
      "type": "string"
    },
    "customer_email": {
      "type": "string"
    },
    "service_id": {
      "type": "string"
    },
    "service_name": {
      "type": "string"
    },
    "service_price": {
      "type": "number"
    },
    "booking_date": {
      "type": "string",
      "format": "date",
      "description": "YYYY-MM-DD"
    },
    "booking_time": {
      "type": "string",
      "description": "HH:MM"
    },
    "end_time": {
      "type": "string",
      "description": "HH:MM calculated end time"
    },
    "duration_minutes": {
      "type": "number"
    },
    "booking_type": {
      "type": "string",
      "enum": [
        "in_store",
        "home_visit"
      ],
      "default": "in_store"
    },
    "address": {
      "type": "string",
      "description": "Human-readable address from map selection"
    },
    "latitude": {
      "type": "number",
      "description": "GPS latitude from map"
    },
    "longitude": {
      "type": "number",
      "description": "GPS longitude from map"
    },
    "delivery_fee": {
      "type": "number",
      "default": 0
    },
    "total_price": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "confirmed",
        "in_progress",
        "completed",
        "cancelled"
      ],
      "default": "pending"
    },
    "item_photos": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Up to 3 photos uploaded by customer"
    },
    "ai_assessment": {
      "type": "string",
      "description": "AI assessment of item condition"
    },
    "notes": {
      "type": "string"
    },
    "staff_notes": {
      "type": "string"
    }
  },
  "required": [
    "booking_number",
    "customer_name",
    "customer_phone",
    "service_id",
    "service_name",
    "booking_date",
    "booking_time",
    "total_price"
  ],
  "rls": {
    "create": {
      "data.customer_email": "{{user.email}}"
    },
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": {
              "$in": [
                "admin",
                "staff"
              ]
            }
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": {
              "$in": [
                "admin",
                "staff"
              ]
            }
          }
        }
      ]
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}