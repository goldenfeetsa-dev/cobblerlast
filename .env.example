# Supabase (مطلوب)
VITE_SUPABASE_URL=https://bwuvldnlfgobqpdfhyql.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Gemini AI (للمساعد الذكي)

# Moyasar (للدفع الإلكتروني)
VITE_MOYASAR_PUBLISHABLE_KEY=pk_live_your-moyasar-key

# ZATCA (الفوترة الإلكترونية)
VITE_ZATCA_SANDBOX=true

# ══════════════════════════════════════════
# برنامج الولاء بالنقاط — Loyalty Membership Program
# (كل ما يلي يُضبط على Vercel كمتغيرات بيئة سيرفر، وليس VITE_*)
# راجع LOYALTY_SETUP.md للتفاصيل الكاملة
# ══════════════════════════════════════════
SUPABASE_URL=https://bwuvldnlfgobqpdfhyql.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Apple Wallet (اختياري — بدونه تبقى النقاط تعمل بدون بطاقة Apple)
APPLE_WWDR_CERTIFICATE_BASE64=
APPLE_PASS_SIGNER_CERT_BASE64=
APPLE_PASS_SIGNER_KEY_BASE64=
APPLE_PASS_SIGNER_KEY_PASSPHRASE=
APPLE_PASS_TYPE_IDENTIFIER=pass.com.yourcompany.loyalty
APPLE_TEAM_IDENTIFIER=

# Google Wallet (اختياري — بدونه تبقى النقاط تعمل بدون بطاقة Google)
GOOGLE_WALLET_SERVICE_ACCOUNT_JSON=
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_CLASS_ID=
